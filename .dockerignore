# Keep the build context small and the image reproducible.

# Virtualenvs (the big one - never ship the host's .venv)
.venv/
venv/

# VCS / IDE / caches
.git/
.gitignore
.idea/
.pytest_cache/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Dev- and docs-only, not needed at runtime
tests/
autoimpl/
*.md
requirements-dev.txt
pytest.ini

# Local env and secrets
.env
.env.*

# The build files themselves
Dockerfile
.dockerignore
docker-compose*.yml